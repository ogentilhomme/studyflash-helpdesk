# Chatwoot (required for docker-compose)
SECRET_KEY_BASE=replace_with_rails_secret  # Run: openssl rand -hex 64
POSTGRES_PASSWORD=postgres
REDIS_URL=redis://redis:6379
FRONTEND_URL=http://localhost:3000

# AI pipeline
ANTHROPIC_API_KEY=

# Chatwoot API (for AI pipeline and seed script - get after Chatwoot setup)
CHATWOOT_API_TOKEN=
CHATWOOT_BASE_URL=http://localhost:3000
CHATWOOT_ACCOUNT_ID=1

# Optional: Enrichment service (Sentry, PostHog, user DB)
# Add only if you use these features
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG_SLUG=
# SENTRY_PROJECT_SLUG=
# POSTHOG_API_KEY=
# INTERNAL_DB_URL=postgresql://user:password@host:5432/studyflash
