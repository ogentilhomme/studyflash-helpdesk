# Chatwoot (required for docker-compose)
SECRET_KEY_BASE=replace_with_rails_secret  # Run: openssl rand -hex 64
POSTGRES_PASSWORD=postgres
REDIS_URL=redis://redis:6379
FRONTEND_URL=http://localhost:3000

# Outlook / Email (for Chatwoot email channel - configure in Chatwoot UI)
IMAP_HOST=outlook.office365.com
IMAP_PORT=993
IMAP_USER=support@studyflash.ch
IMAP_PASSWORD=

SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=support@studyflash.ch
SMTP_PASSWORD=

# Anthropic (AI pipeline)
ANTHROPIC_API_KEY=

# Sentry (enrichment service)
SENTRY_AUTH_TOKEN=
SENTRY_ORG_SLUG=
SENTRY_PROJECT_SLUG=

# PostHog (enrichment service)
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# Internal Postgres (enrichment - user account data)
INTERNAL_DB_URL=postgresql://user:password@host:5432/studyflash

# Chatwoot
CHATWOOT_API_TOKEN=
CHATWOOT_BASE_URL=http://localhost:3000
CHATWOOT_ACCOUNT_ID=1
